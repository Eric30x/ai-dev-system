# AI Dev Platform 环境变量

# 必填：Claude API Key
ANTHROPIC_API_KEY=sk-ant-xxx

# 可选：API Base URL（MiMo 代理等）
ANTHROPIC_BASE_URL=https://api.xiaomimimo.com/anthropic

# 可选：模型名称
MODEL_NAME=mimo-v2.5-pro

# 可选：服务端口（默认 3000）
PORT=3000

# 可选：公网访问地址（用于生成下载链接）
# 部署到 Vercel/Docker 时设置为你的域名
# BASE_URL=https://ai-dev.yourdomain.com
