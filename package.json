{
  "name": "ai-dev",
  "version": "9.0.0",
  "description": "AI Dev Platform — 商业级 AI 自动开发 SaaS 系统",
  "main": "apps/api/index.js",
  "bin": {
    "ai-dev": "bin/cli.js"
  },
  "scripts": {
    "start": "node apps/api/index.js",
    "worker": "node workers/worker-core/index.js",
    "cli": "node index.js",
    "server": "node server/index.js",
    "db:generate": "npx prisma generate --schema=./db/schema.prisma",
    "db:push": "npx prisma db push --schema=./db/schema.prisma",
    "db:migrate": "npx prisma migrate dev --schema=./db/schema.prisma",
    "db:studio": "npx prisma studio --schema=./db/schema.prisma",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["ai", "saas", "claude", "auto-dev", "platform"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "prisma": {
    "schema": "db/schema.prisma"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@prisma/client": "^6.9.0",
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.40.0",
    "commander": "^15.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fs-extra": "^11.3.5",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "openai": "^5.1.0",
    "stripe": "^18.2.0"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  }
}
